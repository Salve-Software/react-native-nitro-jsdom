{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "nitrojsdom"
  ],
  "ios": {
    "iosModuleName": "NitroJsdom"
  },
  "android": {
    "androidNamespace": [
      "nitrojsdom"
    ],
    "androidCxxLibName": "NitroJsdom"
  },
  "autolinking": {
    "HtmlSandbox": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridHtmlSandbox"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}